# PostgreSQL Configuration (for Docker)
# When using docker-compose, the app will automatically construct POSTGRES_URL from these variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dashboard

# Explicit Prisma adapter URL (preferred for Prisma 7 + adapter-pg)
PRISMA_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dashboard

# Docker runtime hint used by app/lib/prisma.ts hostname rewrite logic
RUNNING_IN_DOCKER=true

# Prisma/Node connection URL (required)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dashboard

# Backward compatibility for legacy postgres client usage
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/dashboard

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000/api/auth