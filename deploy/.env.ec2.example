# This is a REFERENCE/EXAMPLE file only.
# Do NOT manually create or edit .env on EC2.
#
# The GitHub Actions workflow automatically generates a fresh .env file
# on every deploy by reading secrets from GitHub and writing them to EC2.
#
# This file exists only to document what environment variables are needed
# and their expected format. Keep it in version control as documentation.

# Image produced by GitHub Actions
IMAGE_TAG=bunrithbuth/pp:latest

# Internal Postgres container settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=dashboard

# Required app secrets
AUTH_SECRET=replace-with-long-random-secret

# Recommended for next-auth in production
AUTH_URL=http://your-domain-or-ec2-hostname

# Generated by workflow for app + migrator containers
DATABASE_URL=postgresql://postgres:replace-with-strong-password@nextjs-dashboard-postgres-prod:5432/dashboard?schema=public
PRISMA_DATABASE_URL=postgresql://postgres:replace-with-strong-password@nextjs-dashboard-postgres-prod:5432/dashboard?schema=public
